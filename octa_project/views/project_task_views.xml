<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_octa" model="ir.ui.view">
        <field name="name">project.task.form.octa</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="string">Người thực hiện</attribute>
            </xpath>
            
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="supervisor_ids" widget="many2many_tags"/>
                <field name="related_user_ids" widget="many2many_tags"/>
            </xpath>
            
        </field>
    </record>
</odoo>